{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/index.ts",
    "scripts/*.ts"
  ],
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "experiments/**",
    "node_modules/**"
  ],
  "rules": {
    "boundary-violation": "error"
  },
  "boundaries": {
    "zones": [
      {
        "name": "forge-status-transition",
        "patterns": ["src/forge/status/**"]
      },
      {
        "name": "forge-steering-transition",
        "patterns": ["src/forge/steering/**"]
      },
      {
        "name": "forge-command-transition",
        "patterns": ["src/forge/workflow/commands.ts"]
      },
      {
        "name": "forge-core-transition",
        "patterns": ["src/forge/core/closure-attestation.ts"]
      },
      {
        "name": "wiki-router-transition",
        "patterns": ["src/wiki/index.ts"]
      },
      {
        "name": "wiki-forge-transition",
        "patterns": [
          "src/wiki/memory/handover/store.ts",
          "src/wiki/memory/projections/amend.ts",
          "src/wiki/memory/projections/resume.ts",
          "src/wiki/memory/prompt-packet.ts",
          "src/wiki/memory/session-commands.ts",
          "src/wiki/research/adopt.ts"
        ]
      },
      {
        "name": "maintenance-checkpoint",
        "patterns": ["src/maintenance/checkpoint.ts", "src/maintenance/checkpoint/**"]
      },
      {
        "name": "maintenance-readiness",
        "patterns": ["src/maintenance/readiness/**"]
      },
      {
        "name": "maintenance-sync",
        "patterns": ["src/maintenance/sync.ts", "src/maintenance/refresh.ts", "src/maintenance/sync/**"]
      },
      {
        "name": "maintenance-doctor",
        "patterns": ["src/maintenance/doctor.ts", "src/maintenance/dashboard.ts", "src/maintenance/doctor/**"]
      },
      {
        "name": "maintenance-drift",
        "patterns": ["src/maintenance/drift.ts", "src/maintenance/drift/**"]
      },
      {
        "name": "maintenance-shared",
        "patterns": ["src/maintenance/shared/**"]
      },
      {
        "name": "maintenance-health",
        "patterns": [
          "src/maintenance/index.ts",
          "src/maintenance/maintain.ts",
          "src/maintenance/_shared.ts",
          "src/maintenance/commit-check.ts",
          "src/maintenance/discover.ts",
          "src/maintenance/lint-repo.ts",
          "src/maintenance/freshness-classifier.ts",
          "src/maintenance/test-health.ts",
          "src/maintenance/health/**",
          "src/maintenance/lint/**"
        ]
      },
      {
        "name": "wiki",
        "patterns": ["src/wiki/**"]
      },
      {
        "name": "forge",
        "patterns": ["src/forge/**"]
      },
      {
        "name": "shared",
        "patterns": ["src/shared/**"]
      },
      {
        "name": "lib",
        "patterns": ["src/lib/**"]
      }
    ],
    "rules": [
      {
        "from": "shared",
        "allow": ["lib"]
      },
      {
        "from": "lib",
        "allow": ["shared"]
      },
      {
        "from": "forge",
        "allow": ["shared", "lib", "forge-status-transition", "forge-steering-transition", "forge-command-transition", "forge-core-transition"]
      },
      {
        "from": "wiki",
        "allow": ["shared", "lib", "wiki-forge-transition", "maintenance-drift"]
      },
      {
        "from": "forge-status-transition",
        "allow": ["shared", "lib", "forge", "forge-steering-transition", "wiki"]
      },
      {
        "from": "forge-steering-transition",
        "allow": ["shared", "lib", "forge", "forge-status-transition"]
      },
      {
        "from": "forge-command-transition",
        "allow": ["shared", "lib", "forge", "forge-status-transition", "forge-steering-transition"]
      },
      {
        "from": "forge-core-transition",
        "allow": ["shared", "lib", "forge"]
      },
      {
        "from": "wiki-router-transition",
        "allow": [
          "shared",
          "lib",
          "wiki",
          "wiki-forge-transition",
          "forge",
          "forge-command-transition",
          "maintenance-health",
          "maintenance-checkpoint",
          "maintenance-sync",
          "maintenance-doctor",
          "maintenance-drift",
          "maintenance-readiness"
        ]
      },
      {
        "from": "wiki-forge-transition",
        "allow": ["shared", "lib", "wiki", "forge", "forge-status-transition"]
      },
      {
        "from": "maintenance-health",
        "allow": ["shared", "lib", "wiki", "forge", "maintenance-shared", "maintenance-sync", "maintenance-doctor", "maintenance-drift", "maintenance-readiness", "maintenance-checkpoint"]
      },
      {
        "from": "maintenance-checkpoint",
        "allow": ["shared", "lib", "wiki", "forge", "maintenance-shared", "maintenance-health"]
      },
      {
        "from": "maintenance-readiness",
        "allow": ["shared", "lib", "wiki", "forge", "forge-status-transition", "forge-core-transition", "maintenance-shared", "maintenance-health", "maintenance-doctor", "maintenance-drift"]
      },
      {
        "from": "maintenance-sync",
        "allow": ["shared", "lib", "wiki", "maintenance-shared", "maintenance-health", "maintenance-drift", "maintenance-readiness"]
      },
      {
        "from": "maintenance-doctor",
        "allow": ["shared", "lib", "wiki", "maintenance-shared", "maintenance-drift", "maintenance-readiness", "maintenance-health"]
      },
      {
        "from": "maintenance-drift",
        "allow": ["shared", "lib", "wiki"]
      },
      {
        "from": "maintenance-shared",
        "allow": ["shared", "lib", "wiki", "forge", "maintenance-health"]
      }
    ]
  }
}
