{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/index.ts",
    "scripts/*.ts"
  ],
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "experiments/**",
    "node_modules/**"
  ],
  "rules": {
    "boundary-violation": "error"
  },
  "boundaries": {
    "zones": [
      {
        "name": "forge-status-transition",
        "patterns": ["src/forge/status/**"]
      },
      {
        "name": "forge-steering-transition",
        "patterns": ["src/forge/steering/**"]
      },
      {
        "name": "forge-command-transition",
        "patterns": ["src/forge/workflow/commands.ts"]
      },
      {
        "name": "forge-core-transition",
        "patterns": ["src/forge/core/closure-attestation.ts"]
      },
      {
        "name": "wiki-router-transition",
        "patterns": ["src/wiki/index.ts"]
      },
      {
        "name": "wiki-forge-transition",
        "patterns": [
          "src/wiki/memory/handover/store.ts",
          "src/wiki/memory/projections/amend.ts",
          "src/wiki/memory/projections/resume.ts",
          "src/wiki/memory/prompt-packet.ts",
          "src/wiki/memory/session-commands.ts",
          "src/wiki/research/adopt.ts"
        ]
      },
      {
        "name": "health-checkpoint",
        "patterns": ["src/health/checkpoint.ts", "src/health/checkpoint/**"]
      },
      {
        "name": "health-readiness",
        "patterns": ["src/health/readiness/**"]
      },
      {
        "name": "health-sync",
        "patterns": ["src/health/sync.ts", "src/health/refresh.ts", "src/health/sync/**"]
      },
      {
        "name": "health-doctor",
        "patterns": ["src/health/doctor.ts", "src/health/dashboard.ts", "src/health/doctor/**"]
      },
      {
        "name": "health-drift",
        "patterns": ["src/health/drift.ts", "src/health/drift/**"]
      },
      {
        "name": "health-shared",
        "patterns": ["src/health/shared/**"]
      },
      {
        "name": "health-core",
        "patterns": [
          "src/health/index.ts",
          "src/health/maintain.ts",
          "src/health/_shared.ts",
          "src/health/commit-check.ts",
          "src/health/discover.ts",
          "src/health/lint-repo.ts",
          "src/health/freshness-classifier.ts",
          "src/health/test-health.ts",
          "src/health/health/**",
          "src/health/lint/**"
        ]
      },
      {
        "name": "wiki",
        "patterns": ["src/wiki/**"]
      },
      {
        "name": "forge",
        "patterns": ["src/forge/**"]
      },
      {
        "name": "shared",
        "patterns": ["src/shared/**"]
      },
      {
        "name": "lib",
        "patterns": ["src/lib/**"]
      }
    ],
    "rules": [
      {
        "from": "shared",
        "allow": ["lib"]
      },
      {
        "from": "lib",
        "allow": ["shared"]
      },
      {
        "from": "forge",
        "allow": ["shared", "lib", "forge-status-transition", "forge-steering-transition", "forge-command-transition", "forge-core-transition"]
      },
      {
        "from": "wiki",
        "allow": ["shared", "lib", "wiki-forge-transition", "health-drift"]
      },
      {
        "from": "forge-status-transition",
        "allow": ["shared", "lib", "forge", "forge-steering-transition", "wiki"]
      },
      {
        "from": "forge-steering-transition",
        "allow": ["shared", "lib", "forge", "forge-status-transition"]
      },
      {
        "from": "forge-command-transition",
        "allow": ["shared", "lib", "forge", "forge-status-transition", "forge-steering-transition"]
      },
      {
        "from": "forge-core-transition",
        "allow": ["shared", "lib", "forge"]
      },
      {
        "from": "wiki-router-transition",
        "allow": [
          "shared",
          "lib",
          "wiki",
          "wiki-forge-transition",
          "forge",
          "forge-command-transition",
          "health-core",
          "health-checkpoint",
          "health-sync",
          "health-doctor",
          "health-drift",
          "health-readiness"
        ]
      },
      {
        "from": "wiki-forge-transition",
        "allow": ["shared", "lib", "wiki", "forge", "forge-status-transition"]
      },
      {
        "from": "health-core",
        "allow": ["shared", "lib", "wiki", "forge", "health-shared", "health-sync", "health-doctor", "health-drift", "health-readiness", "health-checkpoint"]
      },
      {
        "from": "health-checkpoint",
        "allow": ["shared", "lib", "wiki", "forge", "health-shared", "health-core"]
      },
      {
        "from": "health-readiness",
        "allow": ["shared", "lib", "wiki", "forge", "forge-status-transition", "forge-core-transition", "health-shared", "health-core", "health-doctor", "health-drift"]
      },
      {
        "from": "health-sync",
        "allow": ["shared", "lib", "wiki", "health-shared", "health-core", "health-drift", "health-readiness"]
      },
      {
        "from": "health-doctor",
        "allow": ["shared", "lib", "wiki", "health-shared", "health-drift", "health-readiness", "health-core"]
      },
      {
        "from": "health-drift",
        "allow": ["shared", "lib", "wiki"]
      },
      {
        "from": "health-shared",
        "allow": ["shared", "lib", "wiki", "forge", "health-core"]
      }
    ]
  }
}
